<mvc:View
    controllerName="edusupport.platform.controller.auth.Login"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    
    <Page
        showHeader="false"
        class="loginPage">
        
        <content>
            <FlexBox
                direction="Column"
                alignItems="Center"
                justifyContent="Center"
                class="loginContainer">
                
                <VBox 
                    alignItems="Center" 
                    class="loginBox">
                    
                    <!-- Logo ve Başlık -->
                    <core:Icon 
                        src="sap-icon://education" 
                        size="4rem" 
                        color="#6C63FF"
                        class="loginLogo"/>
                    
                    <Title 
                        text="EduSupport" 
                        level="H2" 
                        class="loginTitle"/>
                    
                    <Text 
                        text="Yönetim Paneli" 
                        class="loginSubtitle"/>
                    
                    <!-- Login Formu -->
                    <VBox class="loginForm" width="100%">
                        
                        <Label text="Kullanıcı Adı" class="loginLabel"/>
                        <Input
                            id="usernameInput"
                            placeholder="Kullanıcı adınızı girin"
                            value="{loginModel>/username}"
                            class="loginInput"/>
                        
                        <Label text="Şifre" class="loginLabel sapUiSmallMarginTop"/>
                        <Input
                            id="passwordInput"
                            type="Password"
                            placeholder="Şifrenizi girin"
                            value="{loginModel>/password}"
                            submit="onLogin"
                            class="loginInput"/>
                        
                        <CheckBox 
                            text="Beni Hatırla" 
                            selected="{loginModel>/rememberMe}"
                            class="sapUiSmallMarginTop"/>
                        
                        <Button
                            text="Giriş Yap"
                            type="Emphasized"
                            width="100%"
                            press="onLogin"
                            icon="sap-icon://log"
                            class="loginButton sapUiMediumMarginTop"/>
                        
                        <Link
                            text="Şifremi Unuttum"
                            press="onForgotPassword"
                            class="forgotPasswordLink sapUiSmallMarginTop"/>
                        
                        <HBox 
                            alignItems="Center" 
                            justifyContent="Center"
                            class="sapUiMediumMarginTop">
                            <core:Icon 
                                src="sap-icon://arrow-left" 
                                size="1rem" 
                                color="#6C63FF"
                                class="sapUiTinyMarginEnd"/>
                            <Link 
                                text="Ana Sayfaya Dön" 
                                press="onBackToHome"
                                class="backLink"/>
                        </HBox>
                    </VBox>
                </VBox>
                
                <!-- Test Bilgisi -->
                <VBox alignItems="Center" class="testInfo sapUiLargeMarginTop">
                    <Text text="Test Kullanıcısı" class="testInfoTitle"/>
                    <Text text="Kullanıcı Adı: admin" class="testInfoText"/>
                    <Text text="Şifre: admin123" class="testInfoText"/>
                </VBox>
            </FlexBox>
        </content>
    </Page>
</mvc:View>