<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog
        id="donateDialog"
        title="Bağış Yap 💛"
        contentWidth="500px"
        draggable="true"
        resizable="false">

        <content>
            <ScrollContainer height="540px" vertical="true">
                <VBox class="sapUiSmallMargin">

                    <!-- TUTAR -->
                    <VBox class="sapUiSmallMarginBottom">
                        <Label text="Bağış Tutarı (₺)" design="Bold" class="sapUiTinyMarginBottom"/>
                        <Select id="donateAmountSelect" change="onSelectAmount" width="200px">
                            <items>
                                <core:Item key="50"   text="50 ₺"/>
                                <core:Item key="100"  text="100 ₺"/>
                                <core:Item key="250"  text="250 ₺"/>
                                <core:Item key="500"  text="500 ₺"/>
                                <core:Item key="1000" text="1000 ₺"/>
                                <core:Item key="0"    text="Diğer miktar..."/>
                            </items>
                        </Select>
                        <Input
                            id="donateAmount"
                            placeholder="Tutar girin (min. 10 ₺)"
                            type="Number"
                            value="{donateModel>/amount}"
                            width="200px"
                            class="sapUiTinyMarginTop"/>
                    </VBox>

                    <!-- ÖDEME YÖNTEMİ -->
                    <VBox class="sapUiSmallMarginBottom">
                        <Label text="Ödeme Yöntemi" design="Bold" class="sapUiTinyMarginBottom"/>
                        <SegmentedButton
                            id="paymentMethodBtn"
                            selectionChange="onPaymentMethodChange"
                            selectedKey="{donateModel>/method}">
                            <items>
                                <SegmentedButtonItem key="iban"   text="🏦 IBAN / Havale"/>
                                <SegmentedButtonItem key="iyzico" text="💳 Kredi Kartı"/>
                            </items>
                        </SegmentedButton>
                    </VBox>

                    <!-- KİŞİSEL BİLGİLER -->
                    <f:SimpleForm
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="4" labelSpanL="4" labelSpanM="12" labelSpanS="12"
                        columnsXL="1" columnsL="1" columnsM="1">
                        <f:content>
                            <core:Title text="Kişisel Bilgiler"/>
                            <Label text="Ad Soyad" required="true"/>
                            <Input id="donateName"  placeholder="Adınız Soyadınız" value="{donateModel>/name}"/>
                            <Label text="E-posta" required="true"/>
                            <Input id="donateEmail" placeholder="ornek@email.com"  value="{donateModel>/email}" type="Email"/>
                            <Label text="Telefon"/>
                            <Input id="donatePhone" placeholder="05XX XXX XX XX"   value="{donateModel>/phone}" type="Tel"/>
                            <Label text="Mesaj (isteğe bağlı)"/>
                            <TextArea id="donateNote" placeholder="Bir mesaj bırakın..." value="{donateModel>/note}" rows="2"/>
                        </f:content>
                    </f:SimpleForm>

                    <!-- IBAN BİLGİLERİ -->
                    <VBox id="ibanInfoBox" visible="{= ${donateModel>/method} === 'iban' }" class="sapUiSmallMarginTop">
                        <MessageStrip
                            text="Formu gönderdikten sonra IBAN ve referans kodunuz gösterilecektir."
                            type="Information" showIcon="true" class="sapUiTinyMarginBottom"/>
                        <Panel>
                            <content>
                                <VBox class="sapUiSmallMargin">
                                    <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                                        <Label text="Banka:" design="Bold"/>
                                        <Text text="Ziraat Bankası"/>
                                    </HBox>
                                    <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                                        <Label text="Hesap Sahibi:" design="Bold"/>
                                        <Text text="Pati ve Gelecek Derneği"/>
                                    </HBox>
                                    <HBox justifyContent="SpaceBetween">
                                        <Label text="IBAN:" design="Bold"/>
                                        <Text text="TR00 0000 0000 0000 0000 0000 00"/>
                                    </HBox>
                                </VBox>
                            </content>
                        </Panel>
                    </VBox>

                    <!-- KART BİLGİLERİ -->
                    <VBox id="cardInfoBox" visible="{= ${donateModel>/method} === 'iyzico' }">
                        <MessageStrip
                            text="Test modu — Kart: 5528790000000008 · SKT: 12/2030 · CVV: 123"
                            type="Warning" showIcon="true" class="sapUiTinyMarginBottom"/>
                        <f:SimpleForm
                            editable="true"
                            layout="ResponsiveGridLayout"
                            labelSpanXL="4" labelSpanL="4" labelSpanM="12" labelSpanS="12"
                            columnsXL="1" columnsL="1" columnsM="1">
                            <f:content>
                                <core:Title text="Kart Bilgileri"/>
                                <Label text="Kart Üzerindeki Ad" required="true"/>
                                <Input id="cardHolder" placeholder="AD SOYAD" value="{donateModel>/card_holder}"/>
                                <Label text="Kart Numarası" required="true"/>
                                <Input id="cardNumber" placeholder="5528790000000008" value="{donateModel>/card_number}" maxLength="16"/>
                                <Label text="Son Kullanma" required="true"/>
                                <HBox>
                                    <Input id="cardMonth" placeholder="AA"   value="{donateModel>/expire_month}" maxLength="2" width="80px" class="sapUiTinyMarginEnd"/>
                                    <Input id="cardYear"  placeholder="YYYY" value="{donateModel>/expire_year}"  maxLength="4" width="100px"/>
                                </HBox>
                                <Label text="CVV" required="true"/>
                                <Input id="cardCvc" placeholder="123" value="{donateModel>/cvc}" maxLength="3" width="80px" type="Password"/>
                            </f:content>
                        </f:SimpleForm>
                    </VBox>

                    <!-- GÜVENLİK -->
                    <HBox alignItems="Center" class="sapUiSmallMarginTop">
                        <core:Icon src="sap-icon://locked" size="1rem" color="#10B981" class="sapUiTinyMarginEnd"/>
                        <Text text="Güvenli ödeme · SSL şifreli · Bilgileriniz korunur"/>
                    </HBox>

                </VBox>
            </ScrollContainer>
        </content>

        <beginButton>
            <Button
                text="{= ${donateModel>/method} === 'iban' ? 'Bağış Kaydını Oluştur' : 'Ödemeyi Tamamla' }"
                type="Emphasized"
                icon="sap-icon://heart"
                press="onSubmitDonate"/>
        </beginButton>
        <endButton>
            <Button text="İptal" type="Transparent" press="onCloseDonateDialog"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>