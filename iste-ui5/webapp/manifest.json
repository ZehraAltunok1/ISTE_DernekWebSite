{
  "_version": "1.59.0",
  "sap.app": {
    "id": "edusupport.platform",
    "type": "application",
    "title": "İSTE Dernek",
    "description": "Eğitim Bağış ve Burs Yönetim Sistemi",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "edusupport.platform.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.layout": {},
        "sap.f": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "edusupport.platform.i18n.i18n"
        }
      },
      "appData": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "resources": {
      "css": [
          
        { "uri": "css/design-tokens.css" },
        { "uri": "css/designsystem.css" },
        { "uri": "css/dashboard.css"      }, 
        { "uri": "css/navbar.css"         },
        { "uri": "css/icon-colors.css"    },
        { "uri": "css/profile.css"        },
        { "uri": "css/login.css"          },
        { "uri": "css/mediaCards.css"     },
        { "uri": "css/Campaigndetail.css" },
        { "uri": "css/mediaDetail.css"    },
        { "uri": "css/stats.css"          },
        { "uri": "css/about.css"          }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "type": "View",
        "viewType": "XML",
        "path": "edusupport.platform.view",
        "controlId": "appContent",
        "controlAggregation": "pages",
        "transition": "slide",
        "bypassed": {
          "target": "notFound"
        },
        "async": true
      },
      "routes": [
        { "pattern": "",                    "name": "home",           "target": "home"           },
        { "pattern": "login",               "name": "login",          "target": "login"          },
        { "pattern": "register",            "name": "register",       "target": "register"       },
        { "pattern": "admin/dashboard",     "name": "adminDashboard", "target": "adminDashboard" },
        { "pattern": "admin/profile",       "name": "profile",        "target": "profile"        },
        { "pattern": "bagis",               "name": "donate",         "target": "donate"         },
        { "pattern": "campaign",            "name": "campaignDetail", "target": "campaignDetail" },
        { "pattern": "mediaDetail/{type}/{id}",   "name": "mediaDetail",    "target": "mediaDetail"    },
        {"pattern": "about",                "name": "about",          "target": "about"},
        { "pattern": "reset-password/{token}", "name": "resetPassword", "target": "resetPassword" }
      ],
      "targets": {
        "login": {
          "viewType": "XML",
          "viewName": "auth.Login",
          "viewId": "login",
          "viewLevel": 1
        },
        "register": {
          "viewType": "XML",
          "viewName": "auth.Register",
          "viewId": "register",
          "viewLevel": 1
        },
        "home": {
          "viewType": "XML",
          "viewName": "public.Home",
          "viewId": "home",
          "viewLevel": 2
        },
        "adminDashboard": {
          "viewType": "XML",
          "viewName": "admin.Dashboard",
          "viewId": "adminDashboard",
          "viewLevel": 3
        },
        "profile": {
          "viewType": "XML",
          "viewName": "admin.Profile",
          "viewId": "profile",
          "viewLevel": 4
        },
        "notFound": {
          "viewType": "XML",
          "viewName": "public.NotFound",
          "viewId": "notFound",
          "viewLevel": 5
        },
        "donate": {
          "viewType": "XML",
          "viewName": "public.Donate",
          "viewId": "donate",
          "viewLevel": 2
        },
        "campaignDetail": {
          "viewType": "XML",
          "viewId": "Campaigndetail",
          "viewName": "public.Campaigndetail",
          "viewLevel": 2
        },
        "mediaDetail": {
          "viewType": "XML",
          "viewName": "public.MediaDetail",
          "viewId": "mediaDetail",
          "viewLevel": 2
        },
        "about": {
        "viewId": "about",
        "viewName": "public.About",
        "viewLevel": 1,
        "title": "Hakkımızda"
        },
        "resetPassword": {
        "viewType": "XML",
        "viewName": "public.ResetPassword",
        "viewId": "resetPassword",
        "viewLevel": 1
        }

      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  }
}