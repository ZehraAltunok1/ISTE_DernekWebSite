<mvc:View
    controllerName="edusupport.platform.controller.admin.Dashboard"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.f"
    displayBlock="true"
    height="100%">

    <Page
        showHeader="false"
        showFooter="false"
        class="adminDashboardPage">

        <content>
            <IconTabBar
                id="adminIconTabBar"
                select="onTabSelect"
                class="adminIconTabBar"
                expandable="false"
                stretchContentHeight="true"
                applyContentPadding="false">

                <items>

                    <!-- ══ TAB 1: DASHBOARD ══ -->
                    <IconTabFilter
                        icon="sap-icon://business-objects-experience"
                        text="Dashboard"
                        key="dashboard">
                        <ScrollContainer height="100%" vertical="true" class="dashboardScrollContainer">
                            <VBox class="dashboardContent">
                                <HBox justifyContent="SpaceBetween" alignItems="Center" class="welcomeBanner sapUiResponsiveMargin">
                                    <VBox>
                                        <Title text="Hoş geldiniz, {appData>/currentUser/first_name} {appData>/currentUser/last_name}!" level="H2" class="welcomeTitle"/>
                                        <Text text="Son güncelleme: {dashboardData>/lastUpdate}" class="welcomeSubtitle"/>
                                    </VBox>
                                    <!-- color kaldırıldı → .welcomeIcon CSS'te tanımlı -->
                                    <core:Icon src="sap-icon://hello-world" size="4rem" class="welcomeIcon"/>
                                </HBox>
                                <Panel headerText="Platform İstatistikleri" class="sapUiResponsiveMargin">
                                    <layout:Grid defaultSpan="XL3 L3 M6 S12" class="kpiGrid">
                                        <VBox class="kpiCard kpiBlue">
                                            <VBox alignItems="Center" class="kpiCardContent">
                                                <!-- color kaldırıldı → .kpiIconBlue CSS'te tanımlı -->
                                                <core:Icon src="sap-icon://group"       size="2.5rem" class="kpiIcon kpiIconBlue"/>
                                                <Title text="{dashboardData>/stats/totalDonors}"           level="H1" class="kpiNumber"/>
                                                <Text  text="Toplam Bağışçı" class="kpiLabel"/>
                                                <ObjectStatus text="+{dashboardData>/stats/newDonorsThisMonth} bu ay" state="Success" class="kpiTrend"/>
                                            </VBox>
                                        </VBox>
                                        <VBox class="kpiCard kpiGreen">
                                            <VBox alignItems="Center" class="kpiCardContent">
                                                <core:Icon src="sap-icon://study-leave" size="2.5rem" class="kpiIcon kpiIconGreen"/>
                                                <Title text="{dashboardData>/stats/totalStudents}"         level="H1" class="kpiNumber"/>
                                                <Text  text="Burslu Öğrenci" class="kpiLabel"/>
                                                <ObjectStatus text="+{dashboardData>/stats/newStudentsThisMonth} bu ay" state="Success" class="kpiTrend"/>
                                            </VBox>
                                        </VBox>
                                        <VBox class="kpiCard kpiOrange">
                                            <VBox alignItems="Center" class="kpiCardContent">
                                                <core:Icon src="sap-icon://money-bills" size="2.5rem" class="kpiIcon kpiIconOrange"/>
                                                <Title text="{dashboardData>/stats/totalDonationAmount}"   level="H1" class="kpiNumber"/>
                                                <Text  text="Toplam Bağış (₺)" class="kpiLabel"/>
                                                <ObjectStatus text="+{dashboardData>/stats/donationGrowth}% artış" state="Success" class="kpiTrend"/>
                                            </VBox>
                                        </VBox>
                                        <VBox class="kpiCard kpiPurple">
                                            <VBox alignItems="Center" class="kpiCardContent">
                                                <core:Icon src="sap-icon://business-card" size="2.5rem" class="kpiIcon kpiIconPurple"/>
                                                <Title text="{dashboardData>/stats/activeProjects}"        level="H1" class="kpiNumber"/>
                                                <Text  text="Aktif Proje" class="kpiLabel"/>
                                                <ObjectStatus text="{dashboardData>/stats/completedProjects} tamamlandı" state="Information" class="kpiTrend"/>
                                            </VBox>
                                        </VBox>
                                    </layout:Grid>
                                </Panel>
                            </VBox>
                        </ScrollContainer>
                    </IconTabFilter>

                    <!-- ══ TAB 2: ÜYELER ══ -->
                    <IconTabFilter
                        icon="sap-icon://group"
                        text="Üyeler"
                        count="{dashboardData>/stats/totalMembers}"
                        key="members">
                        <VBox class="tabContent">
                            <OverflowToolbar class="sapUiTinyMarginBottom">
                                <Title text="Üye Yönetimi" level="H3"/>
                                <ToolbarSpacer/>
                                <SearchField
                                    width="300px"
                                    placeholder="Ad, soyad, email veya telefon ara..."
                                    search="onSearchMembers"
                                    liveChange="onSearchMembers"/>
                                <Button text="Yeni Üye" icon="sap-icon://add" type="Emphasized" press="onAddMember"/>
                            </OverflowToolbar>
                            <Table
                                id="membersTable"
                                items="{dashboardData>/members}"
                                noDataText="Kayıt bulunamadı"
                                growing="true"
                                growingThreshold="20"
                                growingScrollToLoad="true"
                                class="membersTable">
                                <columns>
                                    <Column width="4rem"><Text text="ID"/></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="Ad Soyad"/></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="Email"/></Column>
                                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="Telefon"/></Column>
                                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="Üye Tipi"/></Column>
                                    <Column><Text text="Durum"/></Column>
                                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="Kayıt Tarihi"/></Column>
                                    <Column width="7rem" hAlign="Center"><Text text="İşlemler"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{dashboardData>id}"/>
                                            <ObjectIdentifier title="{dashboardData>first_name} {dashboardData>last_name}"/>
                                            <Text text="{dashboardData>email}"/>
                                            <Text text="{dashboardData>phone}"/>
                                            <ObjectStatus
                                                text="{= ${dashboardData>user_type} === 'donor' ? 'Bağışçı' : 'Öğrenci' }"
                                                state="{= ${dashboardData>user_type} === 'donor' ? 'Success' : 'Information' }"/>
                                            <ObjectStatus
                                                text="{= ${dashboardData>status} === 'active' ? 'Aktif' : 'Pasif' }"
                                                state="{= ${dashboardData>status} === 'active' ? 'Success' : 'Error' }"/>
                                            <Text text="{dashboardData>created_at}"/>
                                            <HBox justifyContent="Center">
                                                <Button icon="sap-icon://edit"   type="Transparent" tooltip="Düzenle" press="onEditMember"/>
                                                <Button icon="sap-icon://delete" type="Transparent" tooltip="Sil"     press="onDeleteMember"/>
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>

                    <!-- ══ TAB 3: ETKİNLİKLER ══ -->
                    <IconTabFilter
                        icon="sap-icon://appointment-2"
                        text="Notlar"
                        count="{dashboardData>/stats/totalEvents}"
                        key="events">
                        <VBox class="tabContent">
                            <OverflowToolbar class="sapUiTinyMarginBottom">
                                <Title text="Etkinlik Yönetimi" level="H3"/>
                                <ToolbarSpacer/>
                                <Select id="eventFilterStatus" change="onFilterEvents" width="140px">
                                    <items>
                                        <core:Item key=""          text="Tüm Durumlar"/>
                                        <core:Item key="planned"   text="Planlandı"/>
                                        <core:Item key="active"    text="Aktif"/>
                                        <core:Item key="completed" text="Tamamlandı"/>
                                        <core:Item key="cancelled" text="İptal"/>
                                    </items>
                                </Select>
                                <Select id="eventFilterCategory" change="onFilterEvents" width="160px">
                                    <items>
                                        <core:Item key=""         text="Tüm Kategoriler"/>
                                        <core:Item key="toplanti" text="Toplantı"/>
                                        <core:Item key="egitim"   text="Eğitim"/>
                                        <core:Item key="sosyal"   text="Sosyal"/>
                                        <core:Item key="bagis"    text="Bağış"/>
                                        <core:Item key="diger"    text="Diğer"/>
                                    </items>
                                </Select>
                                <Button text="Yeni Etkinlik" icon="sap-icon://add" type="Emphasized" press="onAddEvent"/>
                            </OverflowToolbar>
                            <HBox class="eventKpiRow sapUiSmallMarginBottom" justifyContent="SpaceBetween">
                                <!-- color kaldırıldı → .iconBlue / .iconGreen vb. CSS'te -->
                                <VBox class="eventKpiCard eventKpiBlue" alignItems="Center">
                                    <core:Icon src="sap-icon://appointment-2" size="1.5rem" class="iconBlue"/>
                                    <Title text="{dashboardData>/eventStats/total}"             level="H3" class="eventKpiNumber"/>
                                    <Text  text="Toplam" class="eventKpiLabel"/>
                                </VBox>
                                <VBox class="eventKpiCard eventKpiGreen" alignItems="Center">
                                    <core:Icon src="sap-icon://future" size="1.5rem" class="iconGreen"/>
                                    <Title text="{dashboardData>/eventStats/planned}"           level="H3" class="eventKpiNumber"/>
                                    <Text  text="Planlandı" class="eventKpiLabel"/>
                                </VBox>
                                <VBox class="eventKpiCard eventKpiOrange" alignItems="Center">
                                    <core:Icon src="sap-icon://complete" size="1.5rem" class="iconOrange"/>
                                    <Title text="{dashboardData>/eventStats/completed}"         level="H3" class="eventKpiNumber"/>
                                    <Text  text="Tamamlandı" class="eventKpiLabel"/>
                                </VBox>
                                <VBox class="eventKpiCard eventKpiPurple" alignItems="Center">
                                    <core:Icon src="sap-icon://group" size="1.5rem" class="iconPurple"/>
                                    <Title text="{dashboardData>/eventStats/totalParticipants}" level="H3" class="eventKpiNumber"/>
                                    <Text  text="Toplam Katılımcı" class="eventKpiLabel"/>
                                </VBox>
                            </HBox>
                            <!-- Etkinlik listesi — icon color binding controller'da yapılacak (dynamic binding CSS'e taşınamaz) -->
                            <List id="eventsList" items="{dashboardData>/events}" noDataText="Etkinlik bulunamadı" class="eventsList">
                                <CustomListItem>
                                    <HBox class="eventCard" alignItems="Center">
                                        <VBox class="eventCardIcon" alignItems="Center" justifyContent="Center">
                                            <core:Icon
                                                src="{= ${dashboardData>category} === 'toplanti' ? 'sap-icon://it-instance'  :
                                                         ${dashboardData>category} === 'egitim'   ? 'sap-icon://study-leave' :
                                                         ${dashboardData>category} === 'sosyal'   ? 'sap-icon://family-care' :
                                                         ${dashboardData>category} === 'bagis'    ? 'sap-icon://money-bills' :
                                                         'sap-icon://appointment-2' }"
                                                size="1.75rem"
                                                class="iconPrimary"/>
                                        </VBox>
                                        <VBox class="eventCardBody" justifyContent="Center">
                                            <HBox alignItems="Center">
                                                <Title text="{dashboardData>title}" level="H4" class="eventCardTitle"/>
                                                <ObjectStatus
                                                    text="{= ${dashboardData>status} === 'planned'   ? 'Planlandı'  :
                                                              ${dashboardData>status} === 'active'    ? 'Aktif'      :
                                                              ${dashboardData>status} === 'completed' ? 'Tamamlandı' : 'İptal' }"
                                                    state="{= ${dashboardData>status} === 'planned'   ? 'Information' :
                                                               ${dashboardData>status} === 'active'    ? 'Success'     :
                                                               ${dashboardData>status} === 'completed' ? 'None'        : 'Error' }"
                                                    class="eventStatusBadge"/>
                                            </HBox>
                                            <HBox class="eventCardMeta" alignItems="Center">
                                                <core:Icon src="sap-icon://calendar"           size="0.875rem" class="iconMuted"/>
                                                <Text text="{dashboardData>event_date_tr}"     class="eventMetaText"/>
                                                <core:Icon src="sap-icon://time-entry-request" size="0.875rem" class="iconMuted sapUiTinyMarginBegin"/>
                                                <Text text="{dashboardData>event_time}"        class="eventMetaText"/>
                                                <core:Icon src="sap-icon://map"                size="0.875rem" class="iconMuted sapUiTinyMarginBegin"/>
                                                <Text text="{dashboardData>location}"          class="eventMetaText"/>
                                            </HBox>
                                            <HBox alignItems="Center" class="sapUiTinyMarginTop">
                                                <core:Icon src="sap-icon://group" size="0.8rem" class="iconMuted"/>
                                                <Text text="{dashboardData>registered_count} / {= ${dashboardData>capacity} === 0 ? '∞' : ${dashboardData>capacity} } katılımcı" class="eventMetaText"/>
                                            </HBox>
                                        </VBox>
                                        <VBox justifyContent="Center" alignItems="End" class="eventCardActions">
                                            <Button icon="sap-icon://group" text="Katılımcılar" type="Transparent" press="onViewParticipants" class="sapUiTinyMarginBottom"/>
                                            <HBox>
                                                <Button icon="sap-icon://edit"   type="Transparent" tooltip="Düzenle" press="onEditEvent"/>
                                                <Button icon="sap-icon://delete" type="Transparent" tooltip="Sil"     press="onDeleteEvent"/>
                                            </HBox>
                                        </VBox>
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </VBox>
                    </IconTabFilter>

<!-- ════════════════════════════════════════════════════════
     Dashboard.view.xml — TAB 4: MEDYA bölümünü
     TAMAMEN aşağıdakiyle değiştirin.
     ════════════════════════════════════════════════════════ -->

<IconTabFilter icon="sap-icon://picture" text="Faaliyetler" key="media">
    <ScrollContainer height="100%" vertical="true">
        <VBox class="tabContent">

            <!-- ── Toolbar ── -->
            <OverflowToolbar class="sapUiTinyMarginBottom">
                <Title text="Faaliyetler — Medya Yönetimi" level="H3"/>
                <ToolbarSpacer/>
                <Button text="Fotoğraf Yükle"     icon="sap-icon://upload" type="Emphasized" press="onAddPhoto"  class="sapUiTinyMarginEnd"/>
                <Button text="YouTube Video Ekle"  icon="sap-icon://video"  type="Default"    press="onAddVideo"/>
            </OverflowToolbar>

            <MessageStrip
                text="Buraya eklediğiniz içerikler anasayfada 'Faaliyetlerimiz' bölümünde otomatik görünür. Aynı başlıktaki fotoğraflar grup olarak gösterilir."
                type="Information"
                showIcon="true"
                class="sapUiSmallMarginBottom"/>

            <!-- ══ FİLTRE BANDI ══ -->
            <HBox
                alignItems="Center"
                wrap="Wrap"
                class="mediaFilterBar sapUiSmallMarginBottom">

                <!-- Arama kutusu -->
                <SearchField
                    id="mediaSearchField"
                    width="220px"
                    placeholder="Başlık veya grup adı ara..."
                    liveChange="onMediaFilter"
                    search="onMediaFilter"
                    class="sapUiTinyMarginEnd"/>

                <!-- Tür filtresi -->
                <Select
                    id="mediaTypeFilter"
                    width="160px"
                    change="onMediaFilter"
                    class="sapUiTinyMarginEnd">
                    <items>
                        <core:Item key="all"   text="📁 Tüm Türler"/>
                        <core:Item key="photo" text="📷 Fotoğraflar"/>
                        <core:Item key="video" text="▶ Videolar"/>
                    </items>
                </Select>

                <!-- Tarih filtresi — ay/yıl -->
                <Select
                    id="mediaDateFilter"
                    width="160px"
                    change="onMediaFilter"
                    class="sapUiTinyMarginEnd">
                    <items>
                        <core:Item key="all" text="📅 Tüm Tarihler"/>
                    </items>
                </Select>

                <!-- Filtre temizle -->
                <Button
                    id="mediaClearFilter"
                    text="Filtreyi Temizle"
                    icon="sap-icon://clear-filter"
                    type="Transparent"
                    press="onMediaFilterClear"
                    visible="false"/>

                <!-- Sonuç sayısı -->
                <ToolbarSpacer/>
                <Text id="mediaFilterResultText" text="" class="mediaFilterResultText"/>
            </HBox>

            <!-- ══ FOTOĞRAF GRUPLARI ══ -->
            <Panel
                id="mediaPhotoPanel"
                headerText="📷 Fotoğraf Grupları"
                expandable="true"
                expanded="true"
                class="sapUiSmallMarginBottom">
                <VBox
                    id="photoGroupsEmpty"
                    visible="false"
                    alignItems="Center"
                    class="sapUiMediumMargin">
                    <core:Icon src="sap-icon://picture" size="2rem" class="iconMuted"/>
                    <Text text="Eşleşen fotoğraf grubu bulunamadı." class="sapUiSmallMarginTop"/>
                </VBox>
                <Table
                    id="photoGroupsTable"
                    items="{dashboardData>/mediaGroups}"
                    noDataText="Henüz fotoğraf grubu yok."
                    class="mediaGroupTable">
                    <columns>
                        <Column width="110px"><Text text="Kapak"/></Column>
                        <Column><Text text="Grup Adı / Açıklama"/></Column>
                        <Column width="100px" hAlign="Center"><Text text="Fotoğraf"/></Column>
                        <Column width="120px" minScreenWidth="Tablet" demandPopin="true"><Text text="Tarih"/></Column>
                        <Column width="120px" hAlign="Center"><Text text="İşlemler"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem vAlign="Middle">
                            <cells>
                                <core:HTML content="{= '&lt;img src=&quot;' + ${dashboardData>coverUrl} + '&quot; style=&quot;width:96px;height:68px;object-fit:cover;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.12);&quot; onerror=&quot;this.src=\\\'images/placeholder.jpg\\\'&quot;/&gt;' }"/>
                                <ObjectIdentifier title="{dashboardData>groupTitle}" text="{= ${dashboardData>items/0/description} || '' }"/>
                                <ObjectStatus text="{dashboardData>count} fotoğraf" state="Success" icon="sap-icon://picture"/>
                                <Text text="{dashboardData>created_at_tr}"/>
                                <HBox justifyContent="Center">
                                    <Button icon="sap-icon://edit"   type="Transparent" tooltip="Grubu Düzenle" press="onEditPhotoGroup"   class="sapUiTinyMarginEnd"/>
                                    <Button icon="sap-icon://delete" type="Transparent" tooltip="Grubu Sil"     press="onDeletePhotoGroup"/>
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>

            <!-- ══ VİDEOLAR ══ -->
            <Panel
                id="mediaVideoPanel"
                headerText="▶ Videolar"
                expandable="true"
                expanded="true">
                <Table
                    id="videoTable"
                    items="{dashboardData>/mediaVideos}"
                    noDataText="Henüz video eklenmedi."
                    class="mediaGroupTable">
                    <columns>
                        <Column width="110px"><Text text="Önizleme"/></Column>
                        <Column><Text text="Başlık / Açıklama"/></Column>
                        <Column width="120px" minScreenWidth="Tablet" demandPopin="true"><Text text="Tarih"/></Column>
                        <Column width="120px" hAlign="Center"><Text text="İşlemler"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem vAlign="Middle">
                            <cells>
                                <core:HTML content="{= '&lt;img src=&quot;' + ${dashboardData>thumbnail_url} + '&quot; style=&quot;width:96px;height:68px;object-fit:cover;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.12);&quot;/&gt;' }"/>
                                <ObjectIdentifier title="{dashboardData>title}" text="{dashboardData>description}"/>
                                <Text text="{dashboardData>created_at_tr}"/>
                                <HBox justifyContent="Center">
                                    <Button icon="sap-icon://edit"   type="Transparent" tooltip="Videoyu Düzenle" press="onEditVideo"   class="sapUiTinyMarginEnd"/>
                                    <Button icon="sap-icon://delete" type="Transparent" tooltip="Videoyu Sil"     press="onDeleteMedia"/>
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>

        </VBox>
    </ScrollContainer>
</IconTabFilter>

                    <!-- ══ TAB 5: GÖNÜLLÜLER ══ -->
                    <IconTabFilter id="volunteersTab" text="Gönüllüler" icon="sap-icon://collaborate" key="volunteers">
                        <content>
                            <HBox class="paymentKpiRow sapUiSmallMarginBottom">
                                <VBox class="paymentKpiCard paymentKpiOrange" id="volKpiPending">
                                    <Title text="0" level="H3" id="volKpiPendingNum"/>
                                    <Text text="Bekleyen" class="paymentKpiLabel"/>
                                </VBox>
                                <VBox class="paymentKpiCard paymentKpiGreen" id="volKpiApproved">
                                    <Title text="0" level="H3" id="volKpiApprovedNum"/>
                                    <Text text="Onaylanan" class="paymentKpiLabel"/>
                                </VBox>
                                <VBox class="paymentKpiCard paymentKpiBlue" id="volKpiTotal">
                                    <Title text="0" level="H3" id="volKpiTotalNum"/>
                                    <Text text="Toplam" class="paymentKpiLabel"/>
                                </VBox>
                            </HBox>
                            <Toolbar class="sapUiSmallMarginBottom">
                                <SegmentedButton id="volStatusFilter" selectionChange="onVolStatusFilter">
                                    <items>
                                        <SegmentedButtonItem key="all"      text="Tümü"/>
                                        <SegmentedButtonItem key="pending"  text="⏳ Bekleyen"/>
                                        <SegmentedButtonItem key="approved" text="✅ Onaylı"/>
                                        <SegmentedButtonItem key="rejected" text="❌ Reddedilen"/>
                                    </items>
                                </SegmentedButton>
                                <ToolbarSpacer/>
                                <SearchField
                                    id="volSearchField"
                                    width="280px"
                                    placeholder="Ad, soyad, e-posta veya telefon ara..."
                                    search="onSearchVolunteers"
                                    liveChange="onSearchVolunteers"/>
                                <Button text="Yenile" icon="sap-icon://refresh" press="onLoadVolunteers" class="sapUiTinyMarginBegin"/>
                            </Toolbar>
                            <Table id="volunteersTable" class="volunteersTable" items="{adminData>/volunteers}" noDataText="Başvuru bulunamadı.">
                                <columns>
                                    <Column><Text text="Ad Soyad"/></Column>
                                    <Column><Text text="E-posta"/></Column>
                                    <Column><Text text="Telefon"/></Column>
                                    <Column><Text text="Neden Gönüllü?"/></Column>
                                    <Column><Text text="Alan"/></Column>
                                    <Column><Text text="Tarih"/></Column>
                                    <Column><Text text="Durum"/></Column>
                                    <Column><Text text="İşlem"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{adminData>first_name} {adminData>last_name}"/>
                                            <Text text="{adminData>email}"/>
                                            <Text text="{adminData>phone}"/>
                                            <Link text="📋 Açıklamayı Gör" press="onShowReason"/>
                                            <Text text="{adminData>area_label}"/>
                                            <Text text="{adminData>created_at_tr}"/>
                                            <ObjectStatus text="{adminData>status_label}" state="{adminData>status_state}"/>
                                            <HBox>
                                                <Button text="Onayla" type="Accept"  icon="sap-icon://accept"  visible="{= ${adminData>status} === 'pending' }" press="onApproveVolunteer" class="sapUiTinyMarginEnd"/>
                                                <Button text="Reddet" type="Reject"  icon="sap-icon://decline" visible="{= ${adminData>status} === 'pending' }" press="onRejectVolunteer"  class="sapUiTinyMarginEnd"/>
                                                <Button icon="sap-icon://delete" type="Transparent" tooltip="Sil" visible="{= ${adminData>status} !== 'pending' }" press="onDeleteVolunteer"/>
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </content>
                    </IconTabFilter>

                    <!-- ══ TAB 6: DUYURULAR ══ -->
                    <IconTabFilter
                        icon="sap-icon://bell"
                        text="Duyurular"
                        count="{dashboardData>/annStats/active}"
                        key="announcements">
                        <VBox class="tabContent">
                            <OverflowToolbar class="sapUiTinyMarginBottom">
                                <Title text="Duyuru Yönetimi" level="H3"/>
                                <ToolbarSpacer/>
                                <Select id="annFilterType" change="onFilterAnnouncements" width="150px">
                                    <items>
                                        <core:Item key="all"         text="Tüm Türler"/>
                                        <core:Item key="Information" text="📘 Bilgi"/>
                                        <core:Item key="Success"     text="✅ Başarı"/>
                                        <core:Item key="Warning"     text="⚠️ Uyarı"/>
                                        <core:Item key="Error"       text="❌ Kritik"/>
                                    </items>
                                </Select>
                                <Select id="annFilterStatus" change="onFilterAnnouncements" width="150px" class="sapUiTinyMarginBegin">
                                    <items>
                                        <core:Item key="all"     text="Tüm Durumlar"/>
                                        <core:Item key="active"  text="✅ Aktif"/>
                                        <core:Item key="passive" text="⏸️ Pasif"/>
                                    </items>
                                </Select>
                                <Button text="+ Yeni Duyuru" icon="sap-icon://add" type="Emphasized" press="onAddAnnouncement" class="sapUiTinyMarginBegin"/>
                            </OverflowToolbar>
                            <HBox class="eventKpiRow sapUiSmallMarginBottom" justifyContent="SpaceBetween">
                                <VBox class="eventKpiCard eventKpiBlue" alignItems="Center">
                                    <core:Icon src="sap-icon://bell"   size="1.5rem" class="iconBlue"/>
                                    <Title text="{dashboardData>/annStats/total}"   level="H3" class="eventKpiNumber"/>
                                    <Text  text="Toplam" class="eventKpiLabel"/>
                                </VBox>
                                <VBox class="eventKpiCard eventKpiGreen" alignItems="Center">
                                    <core:Icon src="sap-icon://accept" size="1.5rem" class="iconGreen"/>
                                    <Title text="{dashboardData>/annStats/active}"  level="H3" class="eventKpiNumber"/>
                                    <Text  text="Aktif" class="eventKpiLabel"/>
                                </VBox>
                                <VBox class="eventKpiCard eventKpiOrange" alignItems="Center">
                                    <core:Icon src="sap-icon://pause"  size="1.5rem" class="iconOrange"/>
                                    <Title text="{dashboardData>/annStats/passive}" level="H3" class="eventKpiNumber"/>
                                    <Text  text="Pasif" class="eventKpiLabel"/>
                                </VBox>
                                <VBox class="eventKpiCard eventKpiPurple" alignItems="Center">
                                    <core:Icon src="sap-icon://calendar" size="1.5rem" class="iconPurple"/>
                                    <Title text="{dashboardData>/annStats/today}"   level="H3" class="eventKpiNumber"/>
                                    <Text  text="Bugün Eklenen" class="eventKpiLabel"/>
                                </VBox>
                            </HBox>
                            <List id="announcementsList" items="{dashboardData>/announcements}" noDataText="Duyuru bulunamadı">
                                <CustomListItem>
                                    <HBox class="eventCard" alignItems="Center">
                                        <VBox class="eventCardIcon" alignItems="Center" justifyContent="Center">
                                            <core:Icon
                                                src="{= ${dashboardData>type} === 'Information' ? 'sap-icon://information' :
                                                         ${dashboardData>type} === 'Success'     ? 'sap-icon://accept'      :
                                                         ${dashboardData>type} === 'Warning'     ? 'sap-icon://warning'     :
                                                                                                    'sap-icon://error' }"
                                                size="1.75rem"
                                                class="iconPrimary"/>
                                        </VBox>
                                        <VBox class="eventCardBody" justifyContent="Center">
                                            <HBox alignItems="Center">
                                                <Title text="{dashboardData>title}" level="H4" class="eventCardTitle"/>
                                                <ObjectStatus
                                                    text="{= ${dashboardData>status} === 'active' ? 'Aktif' : 'Pasif' }"
                                                    state="{= ${dashboardData>status} === 'active' ? 'Success' : 'None' }"
                                                    inverted="true"
                                                    class="sapUiTinyMarginBegin"/>
                                            </HBox>
                                            <Text text="{dashboardData>message}" maxLines="2" class="sapUiTinyMarginTop"/>
                                            <HBox alignItems="Center" class="sapUiTinyMarginTop">
                                                <core:Icon src="sap-icon://calendar" size="0.75rem" class="iconMuted"/>
                                                <Text text="{dashboardData>created_at}" class="eventMetaText"/>
                                                <Text text=" · "                        class="eventMetaText"/>
                                                <Text text="{dashboardData>type}"       class="eventMetaText"/>
                                            </HBox>
                                        </VBox>
                                        <VBox justifyContent="Center" alignItems="End" class="eventCardActions">
                                            <Button
                                                text="{= ${dashboardData>status} === 'active' ? 'Pasife Al' : 'Aktif Et' }"
                                                type="{= ${dashboardData>status} === 'active' ? 'Default'   : 'Accept'   }"
                                                press="onToggleAnnouncementStatus"
                                                class="sapUiTinyMarginBottom"/>
                                            <HBox>
                                                <Button icon="sap-icon://edit"   type="Transparent" tooltip="Düzenle" press="onEditAnnouncement"/>
                                                <Button icon="sap-icon://delete" type="Transparent" tooltip="Sil"     press="onDeleteAnnouncement"/>
                                            </HBox>
                                        </VBox>
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </VBox>
                    </IconTabFilter>

                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>