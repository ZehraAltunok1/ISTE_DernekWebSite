<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    
    <Dialog
        title="Şifre Değiştir"
        contentWidth="500px">
        
        <content>
            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="5"
                labelSpanL="5"
                labelSpanM="5"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false">
                
                <f:content>
                    <Label text="Mevcut Şifre" required="true"/>
                    <Input
                        id="currentPassword"
                        type="Password"
                        placeholder="Mevcut şifrenizi girin"
                        required="true"/>
                    
                    <Label text="Yeni Şifre" required="true"/>
                    <Input
                        id="newPassword"
                        type="Password"
                        placeholder="En az 6 karakter"
                        required="true"/>
                    
                    <Label text="Yeni Şifre (Tekrar)" required="true"/>
                    <Input
                        id="confirmPassword"
                        type="Password"
                        placeholder="Yeni şifrenizi tekrar girin"
                        required="true"/>
                </f:content>
            </f:SimpleForm>
            
            <MessageStrip
                text="Şifreniz en az 6 karakter olmalıdır."
                type="Information"
                showIcon="true"
                class="sapUiSmallMarginTop"/>
        </content>
        
        <beginButton>
            <Button
                text="Değiştir"
                type="Emphasized"
                press="onSavePassword"/>
        </beginButton>
        
        <endButton>
            <Button
                text="İptal"
                press="onCancelPasswordChange"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>