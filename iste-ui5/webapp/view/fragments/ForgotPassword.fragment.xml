<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog title="Şifremi Unuttum" contentWidth="420px">
        <content>
            <VBox class="sapUiMediumMargin">

                <VBox alignItems="Center" class="sapUiSmallMarginBottom">
                    <core:Icon src="sap-icon://locked" size="3rem" color="#6C63FF"
                               class="sapUiSmallMarginBottom"/>
                    <Title text="Şifrenizi mi unuttunuz?" level="H4" class="sapUiTinyMarginBottom"/>
                    <Text text="E-posta adresinizi girin, size sıfırlama bağlantısı gönderelim."
                          textAlign="Center"/>
                </VBox>

                <!-- Başarı mesajı -->
                <MessageStrip
                    text="{forgotModel>/successMessage}"
                    type="Success"
                    showIcon="true"
                    visible="{= ${forgotModel>/successMessage} !== '' }"
                    class="sapUiSmallMarginBottom"/>

                <!-- Hata mesajı -->
                <MessageStrip
                    text="{forgotModel>/errorMessage}"
                    type="Error"
                    showIcon="true"
                    visible="{= ${forgotModel>/errorMessage} !== '' }"
                    class="sapUiSmallMarginBottom"/>

                <!-- Başarılıysa formu gizle -->
                <VBox visible="{= ${forgotModel>/successMessage} === '' }">
                    <Label text="E-posta" required="true"/>
                    <Input
                        id="forgotEmail"
                        type="Email"
                        placeholder="ornek@email.com"
                        value="{forgotModel>/email}"
                        submit="onForgotSubmit"
                        class="sapUiSmallMarginBottom"/>

                    <Button
                        text="Sıfırlama Linki Gönder"
                        type="Emphasized"
                        width="100%"
                        press="onForgotSubmit"
                        enabled="{= !${forgotModel>/isLoading} }"
                        icon="sap-icon://email"/>
                </VBox>

            </VBox>
        </content>
        <endButton>
            <Button text="Kapat" press="onCloseForgotDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>