<mvc:View
    controllerName="edusupport.platform.controller.public.Home"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:uxap="sap.uxap"
    xmlns:customData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">

    <uxap:ObjectPageLayout
        id="mainPage"
        showTitleInHeaderContent="true"
        upperCaseAnchorBar="false"
        showAnchorBar="false"
        showFooter="true"
        enableLazyLoading="true">

        <!-- Header Title -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
                <uxap:expandedHeading>
                    <HBox alignItems="Center">
                        <Image src="images/24.png" width="70px" class="headerLogo sapUiTinyMarginEnd"/>
                        <Title text="Pati ve Gelecek Derneği" level="H1"/>
                    </HBox>
                </uxap:expandedHeading>
                <uxap:actions>
                    <Button
                        text="Giriş Yap"
                        icon="sap-icon://customer"
                        type="Emphasized"
                        press="onLoginPress"
                        visible="{= !${appData>/isAuthenticated} }"/> 
                    <Button
                        text="Panel"
                        icon="sap-icon://home"
                        type="Emphasized"
                        press="onNavToLaunchpad"
                        visible="{= ${appData>/isAuthenticated} &amp;&amp; ${appData>/currentUser/role} !== 'admin' }"/>
                    <Button
                        text="Yönetim"
                        type="Default"
                        press="onNavToDashboard"
                        visible="{= ${appData>/isAuthenticated} &amp;&amp; ${appData>/currentUser/role} === 'admin' }"
                        class="btnHeroPrimary sapUiTinyMarginEnd"/>
                    <MenuButton
                        icon="sap-icon://employee"
                        text="{appData>/currentUser/first_name}"
                        type="Transparent"
                        visible="{appData>/isAuthenticated}"
                        menuPosition="BeginBottom">
                        <menu>
                            <Menu>
                                <items>
                                    <MenuItem text="Profilim"  icon="sap-icon://person-placeholder" press="onViewProfile"/>
                                    <MenuItem text="Çıkış Yap" icon="sap-icon://log"               press="onLogout"/>
                                </items>
                            </Menu>
                        </menu>
                    </MenuButton>
                </uxap:actions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>
                                
        <!-- Header Content -->
        <uxap:headerContent>
            <Image
                src="images/23.jpg"
                width="100%"
                height="460px"
                mode="Background"
                class="heroImage"
                alt="EduSupport Hero"/>
            <l:VerticalLayout class="sapUiSmallMargin heroTextOverlay">
                <Title
                    text="Eğitime Destek, Geleceğe Yatırım 🎓"
                    level="H2"
                    class="sapUiSmallMarginBottom"/>
                <Text
                    text="Her bağış bir öğrencinin hayatında gerçek bir fark yaratır..."
                    class="sapUiSmallMarginBottom"/>

                <!-- ↓↓↓ SADECE BURASI DEĞİŞTİ ↓↓↓ -->
                <HBox class="sapUiSmallMarginTop">

                    <!-- Şimdi Bağış Yap — turuncu dolgu -->
                    <Button
                        text="Şimdi Bağış Yap"
                        press="onDonatePress"
                        class="btnHeroPrimary sapUiTinyMarginEnd"/>

                    <!-- Gönüllü Ol — transparan, beyaz border -->
                    <Button
                    text="Gönüllü Ol"
                    press="onVolunteerPress"
                    class="btnHeroOutline sapUiTinyMarginEnd"/>

                    <!-- Burs Başvurusu — çok şeffaf -->
                    <Button
                    text="Burs Başvurusu"
                    press="onScholarshipApply"
                    class="btnHeroGhost"/>

                </HBox>
                <!-- ↑↑↑ SADECE BURASI DEĞİŞTİ ↑↑↑ -->

            </l:VerticalLayout>
        </uxap:headerContent>

        <uxap:sections>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- İSTATİSTİKLER                                      -->
            <!-- ══════════════════════════════════════════════════
            <uxap:ObjectPageSection title="Başarılarımız" id="statsSection">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <l:Grid defaultSpan="XL3 L3 M6 S12" class="sapUiResponsiveMargin">
                                <GenericTile header="Bağışçı" class="sapUiTinyMargin">
                                    <tileContent><TileContent><content>
                                        <NumericContent value="245+" icon="sap-icon://group" valueColor="Good"/>
                                    </content></TileContent></tileContent>
                                </GenericTile>
                                <GenericTile header="Burslu Öğrenci" class="sapUiTinyMargin">
                                    <tileContent><TileContent><content>
                                        <NumericContent value="158" icon="sap-icon://study-leave" valueColor="Good"/>
                                    </content></TileContent></tileContent>
                                </GenericTile>
                                <GenericTile header="Toplam Bağış" class="sapUiTinyMargin">
                                    <tileContent><TileContent><content>
                                        <NumericContent value="1.2M" scale="₺" icon="sap-icon://money-bills" valueColor="Good"/>
                                    </content></TileContent></tileContent>
                                </GenericTile>
                                <GenericTile header="Aktif Kampanya" class="sapUiTinyMargin">
                                    <tileContent><TileContent><content>
                                        <NumericContent value="3" icon="sap-icon://flag" valueColor="Good"/>
                                    </content></TileContent></tileContent>
                                </GenericTile>
                            </l:Grid>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection> -->
            <uxap:ObjectPageSection title="Başarılarımız" id="statsSection">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                            <uxap:blocks>
                                <!-- İÇ KART -->
                                <HBox justifyContent="SpaceAround"
                                    alignItems="Center"
                                    class="statsCard">

                                    <VBox alignItems="Center">
                                        <Title text="1500+" level="H2" class="statsNumber"/>
                                        <Text text="Beslenen Hayvan Sayısı"/>
                                    </VBox>

                                    <VBox alignItems="Center">
                                        <Title text="250+" level="H2" class="statsNumber"/>
                                        <Text text="Burs Verilen Öğrenci Sayısı"/>
                                    </VBox>

                                    <VBox alignItems="Center">
                                        <Title text="400+" level="H2" class="statsNumber"/>
                                        <Text text="Tamamlanan Tedavi"/>
                                    </VBox>

                                    <VBox alignItems="Center">
                                        <Title text="5000+" level="H2" class="statsNumber"/>
                                        <Text text="Gönüllü Sayısı"/>
                                    </VBox>

                                </HBox>
                                </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            <!-- ══════════════════════════════════════════════════ -->
            <!-- FALİYETLERİMİZ                                     -->
            <!-- ══════════════════════════════════════════════════ -->
        <uxap:ObjectPageSection title="Faaliyetlerimiz" id="activitiesSection">
            <uxap:subSections>
                <uxap:ObjectPageSubSection>
                    <uxap:blocks>

                        <!-- Yükleniyor -->
                        <VBox id="mediaLoadingBox" alignItems="Center" class="sapUiMediumMarginTopBottom" visible="true">
                            <BusyIndicator/>
                            <Text text="Yükleniyor..." class="sapUiTinyMarginTop"/>
                        </VBox>

                        <!-- Boş -->
                        <VBox id="mediaEmptyBox" alignItems="Center" class="sapUiMediumMarginTopBottom" visible="false">
                            <core:Icon src="sap-icon://picture" size="3rem" color="#D1D5DB"/>
                            <Text text="Henüz içerik eklenmemiş." class="sapUiSmallMarginTop" textAlign="Center"/>
                        </VBox>

                        <!-- Ana kutu: foto solda, video sağda -->
                        <HBox id="mediaCardsBox" visible="false" alignItems="Start" class="faaliyetlerMainBox">

                            <!-- FOTOĞRAFLAR (sol) -->
                            <VBox id="photoSection" visible="false" class="faaliyetlerGroup">
                                <HBox alignItems="Center" class="faaliyetGroupHeader">
                                    <core:Icon src="sap-icon://picture" color="#0070F2" size="1rem" class="sapUiTinyMarginEnd"/>
                                    <Title text="Fotoğraflar" level="H4" class="faaliyetGroupTitle"/>
                                    <Text id="photoCounter" text="" class="faaliyetCounter"/>
                                </HBox>
                                <HBox alignItems="Center" class="faaliyetSliderRow">
                                    <Button id="photoPrevBtn" icon="sap-icon://navigation-left-arrow" type="Transparent" press="onPhotoPrev" class="faaliyetArrowBtn" visible="false"/>
                                    <VBox id="photoCardArea" class="faaliyetCardArea"/>
                                    <Button id="photoNextBtn" icon="sap-icon://navigation-right-arrow" type="Transparent" press="onPhotoNext" class="faaliyetArrowBtn" visible="false"/>
                                </HBox>
                            </VBox>

                            <!-- AYRAÇ -->
                            <core:HTML id="mediaDivider" visible="false"
                                content="&lt;div class='faaliyetDivider'&gt;&lt;/div&gt;"/>

                            <!-- VİDEOLAR (sağ) -->
                            <VBox id="videoSection" visible="false" class="faaliyetlerGroup">
                                <HBox alignItems="Center" class="faaliyetGroupHeader">
                                    <core:Icon src="sap-icon://video" color="#0070F2" size="1rem" class="sapUiTinyMarginEnd"/>
                                    <Title text="Videolar" level="H4" class="faaliyetGroupTitle"/>
                                    <Text id="videoCounter" text="" class="faaliyetCounter"/>
                                </HBox>
                                <HBox alignItems="Center" class="faaliyetSliderRow">
                                    <Button id="videoPrevBtn" icon="sap-icon://navigation-left-arrow" type="Transparent" press="onVideoPrev" class="faaliyetArrowBtn" visible="false"/>
                                    <VBox id="videoCardArea" class="faaliyetCardArea"/>
                                    <Button id="videoNextBtn" icon="sap-icon://navigation-right-arrow" type="Transparent" press="onVideoNext" class="faaliyetArrowBtn" visible="false"/>
                                </HBox>
                            </VBox>

                        </HBox>

                    </uxap:blocks>
                </uxap:ObjectPageSubSection>
            </uxap:subSections>
        </uxap:ObjectPageSection>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- HAKKIMIZDA                                          -->
            <!-- ══════════════════════════════════════════════════ -->
            <uxap:ObjectPageSection title="Hakkımızda" id="aboutSection">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection title="Biz Kimiz?">
                        <uxap:blocks>
                            <l:BlockLayout>
                                <l:BlockLayoutRow>
                                    <l:BlockLayoutCell>
                                        <Text text="Hatay bölgesinde eğitim hayallerini gerçekleştirmek isteyen ancak ekonomik imkansızlıklar yaşayan yetenekli öğrencilerle, toplumsal sorumluluk bilinciyle hareket eden hayırsever bağışçıları bir araya getiren dijital bir burs platformudur. 2020 yılında İskenderun'da eğitim gönüllüleri tarafından kurulan derneğimiz, bölgedeki eğitim fırsat eşitsizliğini azaltmak ve her yetenekli gencin potansiyelini gerçekleştirmesine katkıda bulunmak amacıyla faaliyet göstermektedir." class="sapUiSmallMarginBottom"/>
                                        <Text text="Maddi durumu ne olursa olsun, her başarılı ve azimli öğrencinin kaliteli eğitim alma hakkını desteklemek, eğitim yoluyla toplumsal eşitsizlikleri azaltmak ve İskenderun başta olmak üzere Hatay bölgesinin gelecek nesilleri için sürdürülebilir bir destek ağı oluşturmaktır."/>
                                    </l:BlockLayoutCell>
                                </l:BlockLayoutRow>
                            </l:BlockLayout>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                    <uxap:ObjectPageSubSection title="Değerlerimiz">
                        <uxap:blocks>
                            <l:Grid defaultSpan="XL4 L4 M6 S12" class="sapUiResponsiveMargin">
                                <ObjectStatus title="Vizyonumuz"  text="Türkiye'de eğitimde fırsat eşitliğini sağlayan öncü platform"          icon="sap-icon://target-group" state="Information" class="sapUiSmallMargin"/>
                                <ObjectStatus title="Misyonumuz"  text="Her öğrencinin potansiyelini gerçekleştirmesine katkıda bulunmak"       icon="sap-icon://lightbulb"    state="Success"     class="sapUiSmallMargin"/>
                                <ObjectStatus title="Değerlerimiz" text="Şeffaflık, güvenilirlik, sosyal sorumluluk ve eşitlik"                 icon="sap-icon://sys-help"     state="Warning"     class="sapUiSmallMargin"/>
                            </l:Grid>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- BURS PROGRAMLARI                                   -->
            <!-- ══════════════════════════════════════════════════ -->
            <uxap:ObjectPageSection title="Burs Programları" id="scholarshipsSection">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <l:Grid defaultSpan="XL4 L4 M6 S12" class="sapUiResponsiveMargin">
                                <Panel headerText="Üniversite Bursu" class="sapUiTinyMarginBottom">
                                    <content><VBox class="sapUiSmallMargin">
                                        <core:Icon src="sap-icon://study-leave"       size="2.5rem" color="#1873B4" class="sapUiSmallMarginBottom"/>
                                        <Text text="Üniversite öğrencilerine yönelik tam veya kısmi eğitim desteği" class="sapUiSmallMarginBottom"/>
                                        <Button text="Detaylı Bilgi" type="Transparent" icon="sap-icon://navigation-right-arrow" iconFirst="false"/>
                                    </VBox></content>
                                </Panel>
                                <Panel headerText="Lise Bursu" class="sapUiTinyMarginBottom">
                                    <content><VBox class="sapUiSmallMargin">
                                        <core:Icon src="sap-icon://learning-assistant" size="2.5rem" color="#FF6B9D" class="sapUiSmallMarginBottom"/>
                                        <Text text="Lise öğrencilerine eğitim materyali ve harçlık desteği" class="sapUiSmallMarginBottom"/>
                                        <Button text="Detaylı Bilgi" type="Transparent" icon="sap-icon://navigation-right-arrow" iconFirst="false"/>
                                    </VBox></content>
                                </Panel>
                                <Panel headerText="Teknoloji Bursu" class="sapUiTinyMarginBottom">
                                    <content><VBox class="sapUiSmallMargin">
                                        <core:Icon src="sap-icon://laptop"            size="2.5rem" color="#10B981" class="sapUiSmallMarginBottom"/>
                                        <Text text="Teknoloji eğitimi alan öğrencilere özel destek programı" class="sapUiSmallMarginBottom"/>
                                        <Button text="Detaylı Bilgi" type="Transparent" icon="sap-icon://navigation-right-arrow" iconFirst="false"/>
                                    </VBox></content>
                                </Panel>
                            </l:Grid>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- BLOG                                               -->
            <!-- ══════════════════════════════════════════════════ -->
            <uxap:ObjectPageSection title="Blog" id="blogSection">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <l:Grid defaultSpan="XL4 L4 M6 S12" class="sapUiResponsiveMargin">
                                <Panel headerText="Eğitimde Fırsat Eşitliği" class="sapUiTinyMarginBottom">
                                    <content><VBox class="sapUiSmallMargin">
                                        <Image src="images/3.jpg" width="100%" height="200px" mode="Image" class="blogThumbnail sapUiSmallMarginBottom"/>
                                        <HBox class="sapUiTinyMarginBottom">
                                            <core:Icon src="sap-icon://newspaper" size="1.5rem" color="#1873B4" class="sapUiTinyMarginEnd"/>
                                            <Text text="15 Şubat 2026"/>
                                        </HBox>
                                        <Text text="Türkiye'de eğitimde fırsat eşitliğinin önemi..." class="sapUiSmallMarginBottom"/>
                                        <Button text="Devamını Oku" type="Transparent" icon="sap-icon://navigation-right-arrow" iconFirst="false"/>
                                    </VBox></content>
                                </Panel>
                                <Panel headerText="Burs Başvuru Rehberi" class="sapUiTinyMarginBottom">
                                    <content><VBox class="sapUiSmallMargin">
                                        <Image src="images/4.jpg" width="100%" height="200px" mode="Image" class="blogThumbnail sapUiSmallMarginBottom"/>
                                        <HBox class="sapUiTinyMarginBottom">
                                            <core:Icon src="sap-icon://document" size="1.5rem" color="#FF6B9D" class="sapUiTinyMarginEnd"/>
                                            <Text text="10 Şubat 2026"/>
                                        </HBox>
                                        <Text text="Burs başvurusu yaparken dikkat edilmesi gereken noktalar..." class="sapUiSmallMarginBottom"/>
                                        <Button text="Devamını Oku" type="Transparent" icon="sap-icon://navigation-right-arrow" iconFirst="false"/>
                                    </VBox></content>
                                </Panel>
                                <Panel headerText="Başarı Hikayeleri" class="sapUiTinyMarginBottom">
                                    <content><VBox class="sapUiSmallMargin">
                                        <Image src="images/1.jpg" width="100%" height="200px" mode="Image" class="blogThumbnail sapUiSmallMarginBottom"/>
                                        <HBox class="sapUiTinyMarginBottom">
                                            <core:Icon src="sap-icon://leads" size="1.5rem" color="#10B981" class="sapUiTinyMarginEnd"/>
                                            <Text text="5 Şubat 2026"/>
                                        </HBox>
                                        <Text text="EduSupport bursuyla hayallerine kavuşan öğrenciler..." class="sapUiSmallMarginBottom"/>
                                        <Button text="Devamını Oku" type="Transparent" icon="sap-icon://navigation-right-arrow" iconFirst="false"/>
                                    </VBox></content>
                                </Panel>
                            </l:Grid>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- DUYURULAR  (bu bloğu Home.view.xml'de bulun       -->
            <!-- ve tamamını aşağıdakiyle değiştirin)              -->
            <!-- ══════════════════════════════════════════════════ -->
            <uxap:ObjectPageSection title="Duyurular" id="announcementsSection">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <VBox>
                                <!-- Yükleniyor -->
                                <VBox id="annLoadingBox" alignItems="Center" visible="true" class="sapUiSmallMarginBottom">
                                    <BusyIndicator/>
                                </VBox>
                                <!-- Duyuru yok -->
                                <VBox id="annEmptyBox" alignItems="Center" visible="false" class="sapUiSmallMarginBottom">
                                    <Text text="Şu an aktif duyuru bulunmuyor." textAlign="Center"/>
                                </VBox>
                                <!-- Duyurular buraya JS ile eklenir -->
                                <VBox id="annListBox" visible="false"/>
                            </VBox>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- NASIL ÇALIŞIR                                      -->
            <!-- ══════════════════════════════════════════════════ -->
            <uxap:ObjectPageSection title="Nasıl Çalışır?" id="howItWorksSection">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <l:Grid defaultSpan="XL4 L4 M6 S12" class="sapUiResponsiveMargin">
                                <VBox alignItems="Center" class="sapUiSmallMargin">
                                    <Avatar src="sap-icon://edit"        displaySize="L" backgroundColor="Accent1" class="sapUiSmallMarginBottom"/>
                                    <Title text="1. Başvuru"      level="H4" class="sapUiTinyMarginBottom"/>
                                    <Text text="Online başvuru formunu doldurun" textAlign="Center"/>
                                </VBox>
                                <VBox alignItems="Center" class="sapUiSmallMargin">
                                    <Avatar src="sap-icon://decision"    displaySize="L" backgroundColor="Accent2" class="sapUiSmallMarginBottom"/>
                                    <Title text="2. Değerlendirme" level="H4" class="sapUiTinyMarginBottom"/>
                                    <Text text="Başvurular incelenir" textAlign="Center"/>
                                </VBox>
                                <VBox alignItems="Center" class="sapUiSmallMargin">
                                    <Avatar src="sap-icon://money-bills" displaySize="L" backgroundColor="Accent3" class="sapUiSmallMarginBottom"/>
                                    <Title text="3. Destek"       level="H4" class="sapUiTinyMarginBottom"/>
                                    <Text text="Burs sağlanır" textAlign="Center"/>
                                </VBox>
                            </l:Grid>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- ══════════════════════════════════════════════════ -->
            <!-- İLETİŞİM                                           -->
            <!-- ══════════════════════════════════════════════════ 
            <uxap:ObjectPageSection title="İletişim" id="contactSection">
