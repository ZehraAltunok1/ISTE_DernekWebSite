<mvc:View
    controllerName="edusupport.platform.controller.public.ResetPassword"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page showHeader="false" class="sapUiContentPadding">
        <content>
            <FlexBox
                height="100vh"
                alignItems="Center"
                justifyContent="Center">

                <VBox
                    width="420px"
                    class="sapUiMediumMargin"
                    alignItems="Center">

                    <!-- Logo / İkon -->
                    <core:Icon
                        src="sap-icon://locked"
                        size="4rem"
                        color="#2D6A4F"
                        class="sapUiMediumMarginBottom"/>

                    <Title text="Yeni Şifre Belirle" level="H2" class="sapUiSmallMarginBottom"/>
                    <Text
                        text="Lütfen yeni şifrenizi girin."
                        textAlign="Center"
                        class="sapUiSmallMarginBottom"/>

                    <!-- Başarı durumu -->
                    <VBox
                        width="100%"
                        alignItems="Center"
                        visible="{resetModel>/isSuccess}">
                        <core:Icon
                            src="sap-icon://accept"
                            size="3rem"
                            color="#10B981"
                            class="sapUiSmallMarginBottom"/>
                        <Title text="Şifreniz güncellendi!" level="H3" class="sapUiTinyMarginBottom"/>
                        <Text text="Şimdi yeni şifrenizle giriş yapabilirsiniz." class="sapUiSmallMarginBottom"/>
                        <Button
                            text="Giriş Sayfasına Git"
                            type="Emphasized"
                            icon="sap-icon://log"
                            press="onGoToHome"
                            class="sapUiSmallMarginTop"/>
                    </VBox>

                    <!-- Token geçersiz durumu -->
                    <VBox
                        width="100%"
                        alignItems="Center"
                        visible="{resetModel>/isInvalidToken}">
                        <core:Icon
                            src="sap-icon://error"
                            size="3rem"
                            color="#EF4444"
                            class="sapUiSmallMarginBottom"/>
                        <Title text="Link geçersiz veya süresi dolmuş" level="H3" class="sapUiTinyMarginBottom"/>
                        <Text text="Lütfen yeni bir şifre sıfırlama talebinde bulunun." class="sapUiSmallMarginBottom"/>
                        <Button
                            text="Ana Sayfaya Dön"
                            type="Emphasized"
                            press="onGoToHome"
                            class="sapUiSmallMarginTop"/>
                    </VBox>

                    <!-- Reset Formu -->
                    <VBox
                        width="100%"
                        visible="{= !${resetModel>/isSuccess} &amp;&amp; !${resetModel>/isInvalidToken} }">

                        <MessageStrip
                            text="{resetModel>/errorMessage}"
                            type="Error"
                            showIcon="true"
                            visible="{= ${resetModel>/errorMessage} !== '' }"
                            class="sapUiSmallMarginBottom"/>

                        <Label text="Yeni Şifre" required="true"/>
                        <Input
                            type="Password"
                            placeholder="En az 8 karakter"
                            value="{resetModel>/password}"
                            liveChange="onPasswordChange"
                            class="sapUiTinyMarginBottom"/>

                        <!-- Şifre güç göstergesi -->
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <ProgressIndicator
                                width="70%"
                                percentValue="{resetModel>/passwordStrength}"
                                state="{resetModel>/passwordStrengthState}"
                                showValue="false"
                                class="sapUiTinyMarginEnd"/>
                            <Text text="{resetModel>/passwordStrengthText}" class="sapUiTinyMarginBegin"/>
                        </HBox>

                        <Label text="Şifre Tekrar" required="true"/>
                        <Input
                            type="Password"
                            placeholder="Şifrenizi tekrar girin"
                            value="{resetModel>/passwordConfirm}"
                            submit="onResetSubmit"
                            class="sapUiSmallMarginBottom"/>

                        <Button
                            text="Şifremi Güncelle"
                            type="Emphasized"
                            width="100%"
                            icon="sap-icon://save"
                            press="onResetSubmit"
                            enabled="{= !${resetModel>/isLoading} }"/>
                    </VBox>

                </VBox>
            </FlexBox>
        </content>
    </Page>
</mvc:View>