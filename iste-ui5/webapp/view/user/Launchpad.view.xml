<mvc:View
    controllerName="edusupport.platform.controller.user.Launchpad"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    
    <Page
        showHeader="false"
        class="launchpadPage">
        
        <content>
            <!-- FIORI SHELL BAR -->
            <Bar class="fioriShellBar">
                <contentLeft>
                    <HBox alignItems="Center">
                        <core:Icon 
                            src="sap-icon://education" 
                            size="2rem" 
                            color="#FFFFFF"
                            class="sapUiTinyMarginEnd"/>
                        <Title text="EduSupport Platform" level="H3" class="shellBarTitle"/>
                    </HBox>
                </contentLeft>
                <contentMiddle>
                    <Title 
                        text="Hoş geldiniz, {appData>/currentUser/first_name} {appData>/currentUser/last_name}" 
                        level="H5"
                        class="welcomeTitle"/>
                </contentMiddle>
                <contentRight>
                    <Button 
                        icon="sap-icon://bell" 
                        type="Transparent"
                        class="shellBarButton"
                        press="onNotifications"/>
                    <Button 
                        icon="sap-icon://action-settings" 
                        type="Transparent"
                        class="shellBarButton"
                        press="onSettings"/>
                    <Button 
                        text="Çıkış"
                        icon="sap-icon://log" 
                        type="Transparent"
                        class="shellBarButton"
                        press="onLogout"/>
                </contentRight>
            </Bar>
            
            <ScrollContainer 
                vertical="true" 
                horizontal="false"
                height="100%"
                class="launchpadContent">
                
                <!-- ANA MODÜLLER -->
                <Panel 
                    headerText="Ana Modüller" 
                    class="sapUiResponsiveMargin">
                    <GenericTileLayout>
                        
                        <!-- Ana Sayfa -->
                        <GenericTile
                            header="Ana Sayfa"
                            subheader="Bağış platformu"
                            press="onNavToHome"
                            class="fioriTile tileBlue">
                            <TileContent>
                                <ImageContent>
                                    <core:Icon 
                                        src="sap-icon://home" 
                                        size="3rem" 
                                        color="#0070F2"/>
                                </ImageContent>
                            </TileContent>
                        </GenericTile>
                        
                        <!-- Bağış Yap -->
                        <GenericTile
                            header="Bağış Yap"
                            subheader="Eğitime destek ol"
                            press="onNavToDonate"
                            class="fioriTile tilePink">
                            <TileContent>
                                <ImageContent>
                                    <core:Icon 
                                        src="sap-icon://heart" 
                                        size="3rem" 
                                        color="#EC4899"/>
                                </ImageContent>
                            </TileContent>
                        </GenericTile>
                        
                        <!-- Profilim -->
                        <GenericTile
                            header="Profilim"
                            subheader="Hesap bilgileri"
                            press="onNavToProfile"
                            class="fioriTile tileGreen">
                            <TileContent>
                                <ImageContent>
                                    <core:Icon 
                                        src="sap-icon://customer" 
                                        size="3rem" 
                                        color="#10B981"/>
                                </ImageContent>
                            </TileContent>
                        </GenericTile>
                        
                        <!-- Bağışçı için: Bağışlarım -->
                        <GenericTile
                            header="Bağışlarım"
                            subheader="Bağış geçmişi"
                            press="onNavToMyDonations"
                            visible="{= ${appData>/currentUser/user_type} === 'donor' }"
                            class="fioriTile tileOrange">
                            <TileContent>
                                <ImageContent>
                                    <core:Icon 
                                        src="sap-icon://wallet" 
                                        size="3rem" 
                                        color="#F59E0B"/>
                                </ImageContent>
                            </TileContent>
                        </GenericTile>
                        
                        <!-- Öğrenci için: Başvurularım -->
                        <GenericTile
                            header="Burs Başvurum"
                            subheader="Başvuru durumu"
                            press="onNavToMyApplications"
                            visible="{= ${appData>/currentUser/user_type} === 'student' }"
                            class="fioriTile tilePurple">
                            <TileContent>
                                <ImageContent>
                                    <core:Icon 
                                        src="sap-icon://study-leave" 
                                        size="3rem" 
                                        color="#8B5CF6"/>
                                </ImageContent>
                            </TileContent>
                        </GenericTile>
                        
                        <!-- Öğrenci için: Yeni Başvuru -->
                        <GenericTile
                            header="Yeni Başvuru"
                            subheader="Burs başvurusu yap"
                            press="onNavToApply"
                            visible="{= ${appData>/currentUser/user_type} === 'student' }"
                            class="fioriTile tileIndigo">
                            <TileContent>
                                <ImageContent>
                                    <core:Icon 
                                        src="sap-icon://add-document" 
                                        size="3rem" 
                                        color="#6366F1"/>
                                </ImageContent>
                            </TileContent>
                        </GenericTile>
                        
                    </GenericTileLayout>
                </Panel>
                
                <!-- İSTATİSTİKLER -->
                <Panel 
                    headerText="İstatistikler" 
                    class="sapUiResponsiveMargin">
                    <HBox class="kpiContainer">
                        
                        <!-- KPI 1 -->
                        <VBox class="kpiCard kpiBlue" alignItems="Center">
                            <core:Icon 
                                src="sap-icon://group" 
                                size="2.5rem" 
                                color="#0070F2"/>
                            <Title text="245" level="H2" class="kpiNumber"/>
                            <Text text="Toplam Bağışçı" class="kpiLabel"/>
                        </VBox>
                        
                        <!-- KPI 2 -->
                        <VBox class="kpiCard kpiGreen" alignItems="Center">
                            <core:Icon 
                                src="sap-icon://study-leave" 
                                size="2.5rem" 
                                color="#10B981"/>
                            <Title text="158" level="H2" class="kpiNumber"/>
                            <Text text="Burslu Öğrenci" class="kpiLabel"/>
                        </VBox>
                        
                        <!-- KPI 3 -->
                        <VBox class="kpiCard kpiOrange" alignItems="Center">
                            <core:Icon 
                                src="sap-icon://money-bills" 
                                size="2.5rem" 
                                color="#F59E0B"/>
                            <Title text="1.2M ₺" level="H2" class="kpiNumber"/>
                            <Text text="Toplam Bağış" class="kpiLabel"/>
                        </VBox>
                        
                        <!-- KPI 4 - Kullanıcıya Özel -->
                        <VBox 
                            class="kpiCard kpiPurple" 
                            alignItems="Center"
                            visible="{= ${appData>/currentUser/user_type} === 'donor' }">
                            <core:Icon 
                                src="sap-icon://heart" 
                                size="2.5rem" 
                                color="#8B5CF6"/>
                            <Title text="12" level="H2" class="kpiNumber"/>
                            <Text text="Benim Bağışlarım" class="kpiLabel"/>
                        </VBox>
                        
                    </HBox>
                </Panel>
                
                <!-- SON AKTİVİTELER -->
                <Panel 
                    headerText="Son Aktiviteler" 
                    class="sapUiResponsiveMargin">
                    <List
                        noDataText="Henüz aktivite yok"
                        class="activityList">
                        <FeedListItem
                            sender="Ahmet Yılmaz"
                            icon="sap-icon://heart"
                            iconActive="false"
                            text="5,000 ₺ bağış yaptı"
                            timestamp="2 saat önce"/>
                        <FeedListItem
                            sender="Ayşe Demir"
                            icon="sap-icon://study-leave"
                            iconActive="false"
                            text="Burs başvurusu yaptı"
                            timestamp="5 saat önce"/>
                        <FeedListItem
                            sender="Mehmet Kaya"
                            icon="sap-icon://accept"
                            iconActive="false"
                            text="Burs başvurusu onaylandı"
                            timestamp="1 gün önce"/>
                    </List>
                </Panel>
                
            </ScrollContainer>
        </content>
    </Page>
</mvc:View>